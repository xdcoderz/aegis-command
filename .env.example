FINSPARK_ENVIRONMENT=development
FINSPARK_LOG_LEVEL=INFO
FINSPARK_API_HOST=0.0.0.0
FINSPARK_API_PORT=8000
FINSPARK_CORS_ORIGINS=["http://localhost:5173"]
FINSPARK_TRUSTED_HOSTS=["localhost","127.0.0.1","api","testserver"]
FINSPARK_MAX_REQUEST_BYTES=1048576
FINSPARK_DATABASE_URL=postgresql+asyncpg://finspark:finspark@postgres:5432/finspark
FINSPARK_AUTO_CREATE_SCHEMA=false
FINSPARK_MODEL_SEED=2026
FINSPARK_MODEL_CONTAMINATION=0.08
FINSPARK_PQC_REQUIRED=true
FINSPARK_PQC_KEM_ALGORITHM=ML-KEM-768
FINSPARK_PQC_SIGNATURE_ALGORITHM=ML-DSA-65
FINSPARK_AUTH_ENABLED=true
FINSPARK_API_KEYS={"demo-analyst-key-2026":"analyst","demo-admin-key-2026":"admin"}
# FINSPARK_ENFORCEMENT_WEBHOOK_URL=https://pam-gateway.example.internal/finspark
# FINSPARK_ENFORCEMENT_WEBHOOK_SECRET=replace-with-a-long-random-secret
FINSPARK_ENFORCEMENT_TIMEOUT_SECONDS=3
FINSPARK_ENFORCEMENT_MAX_ATTEMPTS=3
FINSPARK_ENFORCEMENT_SANDBOX_ENABLED=true
VITE_API_BASE_URL=http://localhost:8000/api/v1
VITE_API_KEY=demo-analyst-key-2026
VITE_ADMIN_API_KEY=demo-admin-key-2026
