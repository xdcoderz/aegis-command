AEGIS_ENVIRONMENT=development
AEGIS_LOG_LEVEL=INFO
AEGIS_API_HOST=0.0.0.0
AEGIS_API_PORT=8000
AEGIS_CORS_ORIGINS=["http://localhost:5173"]
AEGIS_TRUSTED_HOSTS=["localhost","127.0.0.1","api","testserver"]
AEGIS_MAX_REQUEST_BYTES=1048576
AEGIS_DATABASE_URL=postgresql+asyncpg://aegis:aegis-local@postgres:5432/aegis_command
AEGIS_AUTO_CREATE_SCHEMA=false
AEGIS_MODEL_SEED=2026
AEGIS_MODEL_CONTAMINATION=0.08
AEGIS_PQC_REQUIRED=true
AEGIS_PQC_KEM_ALGORITHM=ML-KEM-768
AEGIS_PQC_SIGNATURE_ALGORITHM=ML-DSA-65
AEGIS_AUTH_ENABLED=true
AEGIS_API_KEYS={"demo-analyst-key-2026":"analyst","demo-admin-key-2026":"admin"}
# AEGIS_ENFORCEMENT_WEBHOOK_URL=https://pam-gateway.example.internal/aegis-command
# AEGIS_ENFORCEMENT_WEBHOOK_SECRET=replace-with-a-long-random-secret
AEGIS_ENFORCEMENT_TIMEOUT_SECONDS=3
AEGIS_ENFORCEMENT_MAX_ATTEMPTS=3
AEGIS_ENFORCEMENT_SANDBOX_ENABLED=true
VITE_API_BASE_URL=http://localhost:8000/api/v1
VITE_API_KEY=demo-analyst-key-2026
VITE_ADMIN_API_KEY=demo-admin-key-2026
